---
layout: null
permalink: /rss.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <link>{{ site.url | absolute_url }}</link>
    <description>{{ site.description | strip_html | strip_newlines | xml_escape }}</description>
    <language>en</language>
    {%- if site.author.name -%}
    <managingEditor>{{ site.author.email | xml_escape }} ({{ site.author.name | xml_escape }})</managingEditor>
    <webMaster>{{ site.author.email | xml_escape }} ({{ site.author.name | xml_escape }})</webMaster>
    {%- endif -%}
    <lastBuildDate>{{ site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}</lastBuildDate>
    <atom:link href="{{ '/rss.xml' | absolute_url }}" rel="self" type="application/rss+xml" />
    {%- for post in site.posts -%}
      {%- if post.published != false and post.date -%}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ post.url | absolute_url }}</link>
      <guid isPermaLink="true">{{ post.url | absolute_url }}</guid>
      <pubDate>{{ post.date | date: "%a, %d %b %Y %H:%M:%S %z" }}</pubDate>
      {%- if site.author.name -%}
      <author>{{ site.author.email | xml_escape }} ({{ site.author.name | xml_escape }})</author>
      {%- endif -%}
      {%- if site.show_excerpts -%}
      <description><![CDATA[{{ post.excerpt | strip_html }}]]></description>
      {%- else -%}
      <description><![CDATA[{{ post.content }}]]></description>
      {%- endif -%}
      {%- for tag in post.tags -%}
      <category>{{ tag | xml_escape }}</category>
      {%- endfor -%}
    </item>
      {%- endif -%}
    {%- endfor -%}
  </channel>
</rss>
